@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Parameter Management";
}

<div class="max-w-full mx-auto p-4 space-y-4 w-full h-full">
    <section class="w-full bg-white border border-gray-200 rounded p-4 space-y-4 text-xs">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div>
                <h1 class="text-lg font-semibold text-gray-800">Parameters</h1>
                <p class="text-xs text-gray-500">Manage parameter definitions, units and descriptions.</p>
            </div>
            <div class="flex flex-col sm:flex-row sm:items-center gap-2 w-full md:w-auto">
                <input id="parameterSearchInput"
                    type="text"
                    placeholder="Search parameter..."
                    class="text-xs border border-gray-300 rounded-md px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none w-full sm:w-60" />
                <button id="openAddParameterBtn"
                    type="button"
                    class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-3 py-1.5 rounded-md transition inline-flex items-center gap-1">
                    <i class="bi bi-plus text-[10px]"></i>
                    Add
                </button>
                <button id="exportParameterBtn"
                    type="button"
                    class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-3 py-1.5 rounded-md transition inline-flex items-center gap-1">
                    <i class="bi bi-download text-[10px]"></i>
                    Export
                </button>
            </div>
        </div>
        <div class="overflow-x-auto border border-gray-200 rounded-md">
            <table class="min-w-full text-left text-gray-700">
                <thead class="bg-gray-100 text-gray-600">
                    <tr>
                        <th class="px-4 py-2 font-semibold">Code</th>
                        <th class="px-4 py-2 font-semibold">Name</th>
                        <th class="px-4 py-2 font-semibold">Type</th>
                        <th class="px-4 py-2 font-semibold">Unit</th>
                        <th class="px-4 py-2 font-semibold">Standard</th>
                        <th class="px-4 py-2 font-semibold w-64">Description</th>
                        <th class="px-4 py-2 font-semibold">Created</th>
                        <th class="px-4 py-2 font-semibold">Updated</th>
                        <th class="px-4 py-2 font-semibold text-center">Actions</th>
                    </tr>
                </thead>
                <tbody id="parameterTableBody" class="divide-y divide-gray-200">
                    <tr>
                        <td colspan="9" class="px-4 py-6 text-center text-gray-400">Loading parameters...</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="pt-3 border-t border-gray-100 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between text-[11px] text-gray-600">
            <div id="parameterPaginationInfo">
                Showing 0 of 0 parameters
            </div>
            <div class="flex flex-col sm:flex-row sm:items-center gap-3">
                <label class="flex items-center gap-2 text-xs">
                    <span class="text-gray-500">Rows per page</span>
                    <select id="parameterPageSizeSelect"
                        class="border border-gray-300 rounded-sm px-2 py-1 focus:ring-1 focus:ring-blue-500 focus:outline-none">
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                </label>
                <div class="flex items-center gap-3">
                    <span id="parameterPageIndicator">Page 1 of 1</span>
                    <div class="inline-flex border border-gray-300 rounded-md overflow-hidden">
                        <button type="button" id="parameterPrevPage"
                            class="px-3 py-1.5 text-xs text-gray-600 disabled:opacity-40 disabled:cursor-not-allowed hover:bg-gray-100 transition">
                            Prev
                        </button>
                        <button type="button" id="parameterNextPage"
                            class="px-3 py-1.5 text-xs text-gray-600 border-l border-gray-300 disabled:opacity-40 disabled:cursor-not-allowed hover:bg-gray-100 transition">
                            Next
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Add Parameter Modal -->
<div id="addParameterModal" class="fixed inset-0 bg-black bg-opacity-40 hidden items-start justify-center z-50 p-4 pt-16 transition-all duration-200 opacity-0 -translate-y-5">
    <div class="bg-white rounded-md shadow-2xl w-full max-w-2xl p-5 space-y-4 h-fit">
        <div class="flex justify-between items-center border-b border-gray-200 pb-2">
            <div>
                <h2 class="text-sm font-semibold text-gray-700">Add Parameter</h2>
            </div>
            <button type="button" id="closeAddParameterBtn" class="text-gray-400 hover:text-gray-600">
                <i class="bi bi-x-lg text-xs"></i>
            </button>
        </div>

        <div class="space-y-3 text-xs">
            <div>
                <label class="block font-medium text-gray-700 mb-1">Parameter Code</label>
                <input type="text" id="addParameterCode" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
            </div>
            <div>
                <label class="block font-medium text-gray-700 mb-1">Parameter Name</label>
                <input type="text" id="addParameterName" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block font-medium text-gray-700 mb-1">Parameter Type</label>
                    <select id="addParameterType" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none">
                        <option value="water">Water</option>
                        <option value="air">Air</option>
                    </select>
                </div>
                <div>
                    <label class="block font-medium text-gray-700 mb-1">Unit</label>
                    <input type="text" id="addParameterUnit" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
                </div>
                <div>
                    <label class="block font-medium text-gray-700 mb-1">Standard Value</label>
                    <input type="number" step="0.0001" id="addParameterStandard" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
                </div>
            </div>
            <div>
                <label class="block font-medium text-gray-700 mb-1">Description</label>
                <textarea id="addParameterDescription" rows="3" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none"></textarea>
            </div>
        </div>

        <div class="flex justify-end gap-2 pt-2">
            <button type="button" id="cancelAddParameterBtn" class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-sm transition">
                Cancel
            </button>
            <button type="button" id="saveParameterBtn" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium px-3 py-1.5 rounded-sm transition inline-flex items-center gap-1">
                <i class="bi bi-save text-[11px]"></i>
                Save
            </button>
        </div>
    </div>
</div>

<!-- Edit Parameter Modal -->
<div id="editParameterModal" class="fixed inset-0 bg-black bg-opacity-40 hidden items-start justify-center z-50 p-4 pt-16 transition-all duration-200 opacity-0 -translate-y-5">
    <div class="bg-white rounded-md shadow-lg w-full max-w-2xl p-5 space-y-4 h-fit">
        <div class="flex justify-between items-center border-b border-gray-200 pb-2">
            <div>
                <h2 class="text-sm font-semibold text-gray-700">Edit Parameter</h2>
                <p class="text-[11px] text-gray-500">Update the information and save changes.</p>
            </div>
            <button type="button" id="closeEditParameterBtn" class="text-gray-400 hover:text-gray-600">
                <i class="bi bi-x-lg text-xs"></i>
            </button>
        </div>

        <input type="hidden" id="editParameterCode" />

        <div class="space-y-3 text-xs">
            <div>
                <label class="block font-medium text-gray-700 mb-1">Parameter Code</label>
                <input type="text" id="editParameterCodeDisplay" class="w-full border border-gray-200 bg-gray-100 text-gray-500 rounded-sm px-3 py-1.5" disabled />
            </div>
            <div>
                <label class="block font-medium text-gray-700 mb-1">Parameter Name</label>
                <input type="text" id="editParameterName" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block font-medium text-gray-700 mb-1">Parameter Type</label>
                    <select id="editParameterType" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none">
                        <option value="water">Water</option>
                        <option value="air">Air</option>
                    </select>
                </div>
                <div>
                    <label class="block font-medium text-gray-700 mb-1">Unit</label>
                    <input type="text" id="editParameterUnit" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
                </div>
                <div>
                    <label class="block font-medium text-gray-700 mb-1">Standard Value</label>
                    <input type="number" step="0.0001" id="editParameterStandard" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
                </div>
            </div>
            <div>
                <label class="block font-medium text-gray-700 mb-1">Description</label>
                <textarea id="editParameterDescription" rows="3" class="w-full border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none"></textarea>
            </div>
        </div>

        <div class="flex justify-between items-center pt-2">
            <button type="button" id="deleteParameterBtn" class="text-xs text-red-600 hover:text-red-700 inline-flex items-center gap-1">
                <i class="bi bi-trash-fill"></i>
                Delete Parameter
            </button>
            <div class="flex gap-2">
                <button type="button" id="cancelEditParameterBtn" class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-sm transition">
                    Close
                </button>
                <button type="button" id="updateParameterBtn" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium px-3 py-1.5 rounded-sm transition inline-flex items-center gap-1">
                    <i class="bi bi-save"></i>
                    Save changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.parameterRoutes = {
            list: '@Url.Action("ListData", "Parameters")',
            detail: '@Url.Action("DetailData", "Parameters")',
            create: '@Url.Action("CreateAjax", "Parameters")',
            update: '@Url.Action("UpdateAjax", "Parameters")',
            delete: '@Url.Action("DeleteAjax", "Parameters")',
            restore: '@Url.Action("RestoreAjax", "Parameters")',
            export: '@Url.Action("ExportCsv", "Parameters")'
        };
    </script>
    <script src="~/js/parameters-management.js" asp-append-version="true"></script>
}
