@model env_analysis_project.Contracts.UserProfile.UserProfileResponse
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Profile";
}

<form id="profileAntiForgeryForm" method="post" class="hidden">
    @Html.AntiForgeryToken()
</form>

<div class="max-w-full mx-auto p-4 space-y-4 w-full h-full">
    <section class="w-full bg-white border border-gray-200 rounded p-4 space-y-5 text-xs">
        <div>
            <h1 class="text-lg font-semibold text-gray-800">My Profile</h1>
            <p class="text-xs text-gray-500">Review your account details and update your password.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 border border-gray-200 rounded-md p-4 bg-gray-50">
            <div>
                <p class="text-[11px] text-gray-500 mb-1">Full Name</p>
                <p class="text-sm font-medium text-gray-800">@(string.IsNullOrWhiteSpace(Model.FullName) ? "-" : Model.FullName)</p>
            </div>
            <div>
                <p class="text-[11px] text-gray-500 mb-1">Email</p>
                <p class="text-sm font-medium text-gray-800">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</p>
            </div>
            <div>
                <p class="text-[11px] text-gray-500 mb-1">Role</p>
                <p class="text-sm font-medium text-gray-800">@(string.IsNullOrWhiteSpace(Model.Role) ? "-" : Model.Role)</p>
            </div>
            <div>
                <p class="text-[11px] text-gray-500 mb-1">Last Updated</p>
                <p class="text-sm font-medium text-gray-800">@Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</p>
            </div>
        </div>

        <div class="border border-gray-200 rounded-md p-4 space-y-4">
            <div>
                <h2 class="text-sm font-semibold text-gray-700">Change Password</h2>
                <p class="text-xs text-gray-500">Enter a new password and confirm it.</p>
            </div>

            <form id="changePasswordForm" class="space-y-3" onsubmit="return false;">
                <div>
                    <label class="block font-medium text-gray-700 mb-1" for="newPassword">New Password</label>
                    <input id="newPassword" name="newPassword" type="password" minlength="8" required
                           class="w-full md:w-1/2 border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
                </div>
                <div>
                    <label class="block font-medium text-gray-700 mb-1" for="confirmPassword">Confirm Password</label>
                    <input id="confirmPassword" name="confirmPassword" type="password" minlength="8" required
                           class="w-full md:w-1/2 border border-gray-300 rounded-sm px-3 py-1.5 focus:ring-1 focus:ring-blue-500 focus:outline-none" />
                </div>

                <div class="pt-2">
                    <button type="button" id="changePasswordBtn"
                            class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium px-3 py-1.5 rounded-sm transition inline-flex items-center gap-1">
                        <i class="bi bi-key text-[11px]"></i>
                        Update Password
                    </button>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/js/profile.js" asp-append-version="true"></script>
}
